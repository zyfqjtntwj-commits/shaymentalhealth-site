---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Shay Mental Health | Child & Adolescent Therapy in Washington"
  description="Warm, structured support for children, adolescents, and families in Washington."
>
  <div class="kicker">Shay Mental Health</div>
  <h1>Therapy for children, adolescents, and families in Washington</h1>
  <p style="font-size:18px; max-width: 70ch;">
    Warm, structured support grounded in evidence-based care and real-world pediatric crisis work.
    We slow things down enough to understand what’s happening—then build skills that help at home, at school, and in relationships.
  </p>

  <div style="display:flex; gap:12px; flex-wrap:wrap; margin: 18px 0 26px;">
    <a class="btn primary" href="/contact">Request a consultation</a>
    <a class="btn" href="/work-with-me">Read how I work</a>
  </div>

  <div class="grid cols3" style="margin-top: 18px;">
    <div class="card">
      <h3>Calm, practical care</h3>
      <p>Collaborative sessions that balance empathy with structure and clear next steps.</p>
    </div>
    <div class="card">
      <h3>Developmentally informed</h3>
      <p>Support tailored to age, temperament, family system, and the realities of school life.</p>
    </div>
    <div class="card">
      <h3>Coordination-ready</h3>
      <p>With consent, coordination with schools and care teams when it helps momentum.</p>
    </div>
  </div>
</BaseLayout>
