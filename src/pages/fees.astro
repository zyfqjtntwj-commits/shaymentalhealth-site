---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Fees & Logistics | Shay Mental Health">
  <div class="kicker">Fees & Logistics</div>
  <h1>Practical details</h1>

  <div class="grid cols2" style="margin-top:18px;">
    <div class="card">
      <h3>Location</h3>
      <p>Seattle area + telehealth across Washington (as applicable).</p>
      <p class="small">Update this once you confirm in-person location details.</p>
    </div>
    <div class="card">
      <h3>Sessions</h3>
      <p>Typically 50 minutes. Frequency varies based on need and goals.</p>
    </div>
    <div class="card">
      <h3>Fees</h3>
      <p>Add your fee structure here (and any superbill/insurance notes).</p>
    </div>
    <div class="card">
      <h3>Getting started</h3>
      <ol>
        <li>Send a request through the contact page</li>
        <li>Brief consultation (if offered)</li>
        <li>Schedule an intake</li>
      </ol>
    </div>
  </div>
</BaseLayout>
