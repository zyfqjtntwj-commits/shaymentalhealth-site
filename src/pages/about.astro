---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="About | Shay Mental Health">
  <div class="kicker">About</div>
  <h1>Jami Sweeney</h1>
  <p style="max-width: 75ch;">
    I’m a mental health counselor who works with children, adolescents, and families. My approach is warm and structured:
    we name what’s happening, build practical skills, and keep the plan realistic for real life.
  </p>

  <section class="section">
    <h2>How I work</h2>
    <div class="grid cols2">
      <div class="card"><p>Collaborative and skills-forward</p></div>
      <div class="card"><p>Developmentally informed</p></div>
      <div class="card"><p>Trauma-informed and culturally responsive</p></div>
      <div class="card"><p>Calm, steady, and direct when it helps</p></div>
    </div>
  </section>

  <section class="section">
    <h2>Background</h2>
    <div class="card">
      <ul>
        <li>M.A., Child & Adolescent Counseling (University of Washington, 2023)</li>
        <li>M.Ed., Special Education (University of Kansas)</li>
        <li>Clinical experience: community mental health (Youth Eastside Services/CrossPath Counseling)</li>
        <li>Pediatric emergency mental health evaluation experience</li>
        <li>Program development and curriculum leadership (FAST, OWL, trauma-informed agency work)</li>
      </ul>
    </div>
  </section>
</BaseLayout>
