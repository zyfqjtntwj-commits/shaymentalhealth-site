---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Contact | Shay Mental Health">
  <div class="kicker">Contact</div>
  <h1>Request a consultation</h1>
  <p style="max-width: 75ch;">
    If you’d like to explore working together, send a note. Please do not include sensitive clinical details in this message.
  </p>

  <section class="section">
    <div class="card">
      <p><strong>Email:</strong> <a href="mailto:shaymentalhealth@gmail.com">shaymentalhealth@gmail.com</a></p>
      <p><strong>Phone:</strong> <a href="tel:+13462180863">346-218-0863</a></p>
      <p class="small">If you prefer, you can share the age range, general concern (e.g., anxiety, school stress), and scheduling needs.</p>
    </div>
  </section>
</BaseLayout>
